---
export interface Props {
  image: string;
  title: string;
  description: string;
  tags: string[];
  url: string;
}

const { image, title, description, tags = [], url } = Astro.props;
---

<article
  class="rounded overflow-hidden shadow-lg bg-white dark:bg-gray-700"
  data-animate-type="motion-safe:animate-fadeIn"
>
  <img
    class="w-full max-h-40 object-cover"
    src={image}
    alt={title}
    loading="lazy"
  />
  <div class="px-6 py-4">
    <div class="font-bold text-xl mb-2 dark:text-gray-200">
      <a href={url} target="_blank">{title}</a>
    </div>
    <p class="mb-3 text-gray-700 dark:text-gray-200 text-base">{description}</p>
    <a
      href={url}
      target="_blank"
      class="inline-flex items-center text-blue-600 dark:text-[#121819] hover:underline"
    >
      Visitar
      <svg
        class="ml-2 w-5 h-5"
        fill="currentColor"
        viewBox="0 0 20 20"
        xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
        ></path><path
          d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
        ></path>
      </svg>
    </a>
  </div>
  <div class="px-6 pt-4 pb-2">
    {
      tags.map((item) => (
        <span class="inline-block bg-gray-100 rounded-full px-3 py-1 text-sm font-semibold text-gray-700 mr-2 mb-2">
          {item}
        </span>
      ))
    }
  </div>
</article>
