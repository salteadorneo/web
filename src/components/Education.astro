---
export interface Props {
  years: string;
  title: string;
  description: string;
}

const { years, title, description } = Astro.props;
---

<li class="mb-10 ml-4">
  <div
    class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -left-1.5 border border-white dark:border-gray-200 dark:bg-gray-200"
  >
  </div>
  <time
    class="mb-1 text-sm font-normal leading-none text-gray-400 dark:text-gray-200"
  >
    {years}
  </time>
  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
    {title}
  </h3>
  <p class="text-base font-normal text-gray-500 dark:text-gray-200">
    {description}
  </p>
</li>
