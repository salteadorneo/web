---
interface Props {
  title?: string;
  description?: string;
  eyebrow?: string;
  href?: string;
  className?: string;
}

const {
  title,
  description,
  eyebrow,
  href,
  className = "",
} = Astro.props as Props;

const finalClass = `bg-card border border-border rounded-xl p-6 transition-all hover:border-muted hover:shadow-sm ${className}`.trim();
---

<article class={finalClass}>
  {eyebrow && (
    <p class="text-base font-medium text-muted-foreground uppercase tracking-wide">{eyebrow}</p>
  )}

  {title &&
    (href ? (
      <h3 class="mt-3 text-lg font-semibold text-foreground">
        <a href={href} class="hover:text-primary transition-colors">{title}</a>
      </h3>
    ) : (
      <h3 class="mt-3 text-lg font-semibold text-foreground">{title}</h3>
    ))}

  {description && <p class="mt-2 text-base text-muted-foreground leading-relaxed">{description}</p>}

  <slot />
</article>
