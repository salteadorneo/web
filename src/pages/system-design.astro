---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
---

<Layout title="System Design — salteadorneo.dev">
  <Header />
  <main class="max-w-6xl mx-auto px-6 pt-10 pb-24 space-y-24">

    <!-- Intro -->
    <section>
      <p class="font-medium text-muted-foreground tracking-wide uppercase mb-3">
        Referencia de diseño
      </p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
        System Design
      </h1>
      <p class="mt-3 text-lg text-muted-foreground max-w-2xl leading-relaxed">
        Componentes, tokens y patrones que se usan en todo el sitio. Fuente de verdad para mantener coherencia visual.
      </p>
    </section>

    <hr class="border-border" />

    <!-- Colores -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Colores</h2>
      <p class="text-muted-foreground leading-relaxed">Variables CSS definidas en <code class="bg-secondary px-2 py-0.5 rounded text-foreground">global.css</code> bajo <code class="bg-secondary px-2 py-0.5 rounded text-foreground">@theme</code>.</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {[
          { name: "background", cls: "bg-background border border-border" },
          { name: "foreground", cls: "bg-foreground" },
          { name: "primary", cls: "bg-primary" },
          { name: "primary-foreground", cls: "bg-primary-foreground border border-border" },
          { name: "secondary", cls: "bg-secondary" },
          { name: "secondary-foreground", cls: "bg-secondary-foreground" },
          { name: "card", cls: "bg-card border border-border" },
          { name: "border", cls: "bg-border" },
          { name: "muted", cls: "bg-muted" },
          { name: "muted-foreground", cls: "bg-muted-foreground" },
        ].map(({ name, cls }) => (
          <div class="space-y-2">
            <div class={`h-14 rounded-lg ${cls}`} />
            <p class="text-base text-muted-foreground">{name}</p>
          </div>
        ))}
      </div>
    </section>

    <hr class="border-border" />

    <!-- Tipografía -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Tipografía</h2>
      <p class="text-muted-foreground leading-relaxed">La familia base del sitio es <code class="bg-secondary px-2 py-0.5 rounded text-foreground">monospace</code> (definida en global.css). Tamaño mínimo: <code class="bg-secondary px-2 py-0.5 rounded text-foreground">text-base</code>.</p>
      <div class="space-y-5 border border-border rounded-xl divide-y divide-border">
        {[
          { label: "text-6xl font-bold", cls: "text-6xl font-bold text-foreground", sample: "Título hero" },
          { label: "text-5xl font-bold", cls: "text-5xl font-bold text-foreground", sample: "Título sección" },
          { label: "text-4xl font-bold", cls: "text-4xl font-bold text-foreground", sample: "Encabezado H1" },
          { label: "text-3xl font-bold", cls: "text-3xl font-bold text-foreground", sample: "Encabezado H2" },
          { label: "text-2xl font-semibold", cls: "text-2xl font-semibold text-foreground", sample: "Encabezado H3" },
          { label: "text-xl", cls: "text-xl text-foreground", sample: "Subtítulo / intro" },
          { label: "text-lg", cls: "text-lg text-muted-foreground", sample: "Cuerpo grande / descripción principal" },
          { label: "text-base", cls: "text-base text-muted-foreground", sample: "Cuerpo estándar — texto de tarjetas, etiquetas, navigation" },
        ].map(({ label, cls, sample }) => (
          <div class="px-6 py-5 flex flex-col sm:flex-row sm:items-baseline gap-3">
            <code class="shrink-0 text-muted-foreground bg-secondary px-2 py-0.5 rounded w-48">{label}</code>
            <span class={cls}>{sample}</span>
          </div>
        ))}
      </div>
    </section>

    <hr class="border-border" />

    <!-- Botones -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Botones — <code class="text-primary font-medium">Button.astro</code></h2>
      <p class="text-muted-foreground leading-relaxed">Componente <code class="bg-secondary px-2 py-0.5 rounded text-foreground">src/components/ui/Button.astro</code>. Acepta <code class="bg-secondary px-2 py-0.5 rounded text-foreground">href</code> para enlace o se renderiza como <code class="bg-secondary px-2 py-0.5 rounded text-foreground">&lt;button&gt;</code>. Variantes: <code class="bg-secondary px-2 py-0.5 rounded text-foreground">primary</code>, <code class="bg-secondary px-2 py-0.5 rounded text-foreground">secondary</code>, <code class="bg-secondary px-2 py-0.5 rounded text-foreground">outline</code>.</p>
      <div class="flex flex-wrap gap-4">
        <Button href="#" variant="primary">Botón primario</Button>
        <Button href="#" variant="secondary">Botón secundario</Button>
        <Button href="#" variant="outline">Botón outline</Button>
        <Button variant="primary">Botón submit</Button>
      </div>
      <div class="bg-card border border-border rounded-xl p-5 overflow-x-auto">
        <pre class="text-base text-muted-foreground leading-relaxed">{`<Button href="#contacto" variant="primary">Empezar conversación</Button>
<Button href="#proceso" variant="secondary">Ver proceso</Button>
<Button href="#" variant="outline">Saber más</Button>`}</pre>
      </div>
    </section>

    <hr class="border-border" />

    <!-- Tarjetas -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Tarjetas — <code class="text-primary font-medium">Card.astro</code></h2>
      <p class="text-muted-foreground leading-relaxed">Componente <code class="bg-secondary px-2 py-0.5 rounded text-foreground">src/components/ui/Card.astro</code>. Props: <code class="bg-secondary px-2 py-0.5 rounded text-foreground">title</code>, <code class="bg-secondary px-2 py-0.5 rounded text-foreground">description</code>, <code class="bg-secondary px-2 py-0.5 rounded text-foreground">eyebrow</code>, <code class="bg-secondary px-2 py-0.5 rounded text-foreground">href</code>. Acepta <code class="bg-secondary px-2 py-0.5 rounded text-foreground">slot</code> para contenido extra.</p>
      <div class="grid md:grid-cols-3 gap-6">
        <Card
          eyebrow="Ejemplo"
          title="Tarjeta simple"
          description="Descripción corta del contenido de esta tarjeta."
        />
        <Card
          eyebrow="Con enlace"
          title="Tarjeta con href"
          description="El título se convierte en enlace cuando se pasa href."
          href="#"
        />
        <Card eyebrow="Con slot">
          <div class="mt-4 flex flex-wrap gap-2">
            {["Tag 1", "Tag 2", "Tag 3"].map((tag) => (
              <span class="bg-secondary text-muted-foreground px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        </Card>
      </div>
      <div class="bg-card border border-border rounded-xl p-5 overflow-x-auto">
        <pre class="text-base text-muted-foreground leading-relaxed">{`<Card
  eyebrow="Categoría"
  title="Título del proyecto"
  description="Descripción breve del proyecto."
  href="https://ejemplo.com"
/>

<Card eyebrow="Con contenido extra">
  <slot>contenido personalizado</slot>
</Card>`}</pre>
      </div>
    </section>

    <hr class="border-border" />

    <!-- Patrones de sección -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Patrones de sección</h2>
      <p class="text-muted-foreground leading-relaxed">Estructura estándar de secciones usada en <code class="bg-secondary px-2 py-0.5 rounded text-foreground">mvp4</code> y <code class="bg-secondary px-2 py-0.5 rounded text-foreground">vs-lovable</code>.</p>
      <div class="border border-border rounded-xl overflow-hidden divide-y divide-border">
        {[
          {
            name: "Fondo alternado",
            code: `<section class="py-20 px-6 bg-secondary/30">   <!-- sección impar -->
<section class="py-20 px-6">                   <!-- sección par -->`,
          },
          {
            name: "Cabecera de sección",
            code: `<p class="font-medium text-muted-foreground mb-3 tracking-wide uppercase">
  Etiqueta
</p>
<h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
  Título de sección
</h2>
<p class="mt-4 text-lg text-muted-foreground leading-relaxed">
  Descripción de apoyo.
</p>`,
          },
          {
            name: "CTA final (fondo primary)",
            code: `<section class="py-20 px-6 bg-primary text-primary-foreground">
  <div class="max-w-3xl mx-auto text-center">
    <h2>...</h2>
    <Button href="mailto:..." variant="primary">Enviar email</Button>
  </div>
</section>`,
          },
        ].map(({ name, code }) => (
          <div class="px-6 py-5">
            <p class="font-semibold text-foreground mb-3">{name}</p>
            <pre class="text-base text-muted-foreground leading-relaxed overflow-x-auto">{code}</pre>
          </div>
        ))}
      </div>
    </section>

    <hr class="border-border" />

    <!-- Páginas del sistema -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-foreground">Páginas del sistema</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          { href: "/", title: "Index", description: "Blog con listado de artículos." },
          { href: "/proyectos", title: "Proyectos", description: "Proyectos agrupados por categoría." },
          { href: "/mvp4", title: "mvp4", description: "Landing principal de servicios MVP." },
          { href: "/vs-lovable", title: "vs Lovable", description: "Comparativa de servicios vs herramienta." },
        ].map((page) => (
          <Card
            eyebrow={page.href}
            title={page.title}
            description={page.description}
            href={page.href}
          />
        ))}
      </div>
    </section>

  </main>
  <Footer />
</Layout>
