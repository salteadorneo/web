---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";

const groups = [
  {
    label: "Proyectos destacados",
    heading: true,
    projects: [
      {
        title: "Wireframes",
        url: "https://wireframes.salteadorneo.dev",
        description: "Biblioteca de web componentes UI open source.",
        tags: ["Astro", "React", "Tailwind"],
        github: "https://github.com/salteadorneo/wireframes",
      },
      {
        title: "PlayJS",
        url: "https://playjs.dev",
        description: "Playground JavaScript en tu navegador.",
        tags: ["React", "JavaScript"],
        github: "https://github.com/salteadorneo/playjs",
      },
      {
        title: "Agendados",
        url: "https://agendados.es",
        description: "Calendario centralizado de eventos de juegos de mesa, rol y miniaturas en España.",
        tags: ["Astro", "React", "Tailwind"],
        github: "https://github.com/salteadorneo/agendados",
      },
      {
        title: "CSSX",
        url: "https://cssx.js.org",
        description: "Compila CSS como lenguaje de programación. Define estructura HTML y estilos en archivos `.cssx`.",
        tags: ["CSS", "Compiler", "PostCSS"],
        github: "https://github.com/salteadorneo/cssx",
      },
    ],
  },
  {
    label: "Herramientas",
    heading: false,
    projects: [
      {
        title: "Gantt",
        url: "https://gantt.salteadorneo.dev",
        description: "Planifica y visualiza proyectos con diagramas de Gantt directamente en el navegador.",
        tags: ["JavaScript", "Vanilla JS"],
        github: "https://github.com/salteadorneo/gantt",
      },
      {
        title: "Generator",
        url: "https://generator.salteadorneo.dev",
        description: "Generador de datos aleatorios: DNI, NIE, CIF, matrículas.",
        tags: ["Astro", "API REST"],
        github: "https://github.com/salteadorneo/generator",
      },
      {
        title: "ZIP",
        url: "https://zip.salteadorneo.dev",
        description: "Explora y descarga archivos ZIP directamente en el navegador sin descargar el archivo completo.",
        tags: ["JSZip", "JavaScript", "Vanilla JS"],
        github: "https://github.com/salteadorneo/zip",
      },
      {
        title: "Status",
        url: "https://status.salteadorneo.dev",
        description: "Monitor de disponibilidad para GitHub Pages.",
        tags: ["GitHub Actions", "Zero Dependencies"],
        github: "https://salteadorneo/status",
      },
      {
        title: "Changes",
        url: "https://changes.salteadorneo.dev",
        description: "Monitoreo de cambios en URLs con screenshots automáticos.",
        tags: ["Puppeteer", "Node.js"],
        github: "https://github.com/salteadorneo/changes",
      },
    ],
  },
  {
    label: "Juegos",
    heading: false,
    projects: [
      {
        title: "Pokemodle",
        url: "https://pokemodle.salteadorneo.dev/",
        description: "Adivina el Pokémon oculto cada día.",
        tags: ["Vue.js", "Game"],
        github: "https://github.com/salteadorneo/pokemodle",
      },
      {
        title: "Bulbs",
        url: "https://bulbs.salteadorneo.dev",
        description: "¿Puedes adivinar el orden de los focos en un intento?",
        tags: ["Preact", "Game"],
        github: "https://github.com/salteadorneo/bulbs",
      },
      {
        title: "Qubes",
        url: "https://salteadorneodev.itch.io/qubes",
        description: "Juego de puzzle disponible en itch.io y Google Play.",
        tags: ["Game", "Puzzle", "itch.io"],
      },
    ],
  },
  {
    label: "Archivados",
    heading: false,
    archived: true,
    projects: [
      {
        title: "URL Beauty",
        description: "An other URL shortener. But, with magic.",
        tags: ["Deno", "URL Shortener"],
        github: "https://github.com/salteadorneo/url.beauty",
      },
      {
        title: "Clone UI",
        description: "Genera componentes UI con simples prompts.",
        tags: ["Next.js", "Tailwind CSS", "AI"],
      },
      {
        title: "infinite.cards",
        description: "Tarjetas digitales profesionales.",
        tags: ["Next.js", "React"],
      },
      {
        title: "basycss",
        description: "Framework CSS con clases utilitarias.",
        tags: ["CSS", "Framework", "SCSS"],
        github: "https://github.com/salteadorneo/basycss",
      },
    ],
  },
];
---

<Layout title="Proyectos — salteadorneo.dev">
  <Header />
  <main>
    <section class="pt-20 pb-6 px-6 max-w-6xl mx-auto">
      <p class="font-medium text-muted-foreground tracking-wide uppercase mb-3">
        Trabajo
      </p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
        Proyectos destacados
      </h1>
    </section>

    <section class="max-w-6xl mx-auto px-6 pb-20 space-y-16 border-t border-border pt-10">
      {groups.map((group) => (
        <div>
          <h2 class={`text-xl font-semibold mb-6 ${group.archived ? "text-muted-foreground" : "text-foreground"}`}>
            {group.label}
          </h2>
          <div class={`grid gap-6 grid-cols-1 md:grid-cols-2 ${group.archived ? "opacity-40" : ""}`}>
            {group.projects.map((project) => (
              <Card
                eyebrow={project.tags?.join(", ")}
                title={project.title}
                description={project.description}
                href={(project as any).url}
              />
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>
  <Footer />
</Layout>
